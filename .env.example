# Copy this file to .env and fill in real values. Do NOT commit .env.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret

# Keep False in production. Set True only for local debugging.
DEBUG=False

# Comma-separated hostnames allowed to serve the app.
# Locally:   127.0.0.1,localhost
# On Render: your-app.onrender.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated full origins (with scheme) trusted for CSRF.
# On Render: https://your-app.onrender.com
CSRF_TRUSTED_ORIGINS=

# Supabase PostgreSQL connection string (URI).
# Leave blank locally to use SQLite. Set in production / when migrating data.
# Example: postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=
